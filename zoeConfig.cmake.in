@PACKAGE_INIT@

if(NOT "@ZOE_BUILD_SHARED_LIBS@")
    include(CMakeFindDependencyMacro)
    find_dependency(CURL CONFIG)
    if("@OpenSSL_FOUND@")
        find_dependency(OpenSSL)
    endif()
    if(NOT WIN32)
        find_dependency(Threads)
    endif()
endif()

include("${CMAKE_CURRENT_LIST_DIR}/zoeTargets.cmake")
